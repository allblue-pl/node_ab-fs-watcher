{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "declaration": true,
        "erasableSyntaxOnly": true,
        "module": "nodenext",
        "outDir": "lib",
        "rewriteRelativeImportExtensions": true,
        "rootDir": "ts-lib",
        "strict": true,
        "target": "esnext",
        "typeRoots": [
            "./node_modules/@types", 
            "./js-modules"
        ],
        "types": ["anymatch", "node"],
        "useDefineForClassFields": true,
        "verbatimModuleSyntax": true
    },
    "exclude": [
        "./lib/**/*",
        "./tests/**/*",
        "./index.d.ts",
        "./index.js"
    ]
}